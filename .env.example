# opencode backend connection — example / template.
# copy to `.env` and fill in the blanks. `.env` is gitignored.

# ── required ────────────────────────────────────────────────────────────
# base URL of your opencode instance. default is :4096; this repo typically
# targets :4097 to stay isolated from the ollama-swarm sibling app that
# also binds :4096 by default.
OPENCODE_URL=http://localhost:4096

# ── optional auth ───────────────────────────────────────────────────────
# HTTP Basic auth. leave both empty if your opencode has no auth.
# both values are server-side only — never shipped to the browser.
OPENCODE_BASIC_USER=
OPENCODE_BASIC_PASS=

# ── optional paths ──────────────────────────────────────────────────────
# swarm-run state directory. defaults to `.opencode_swarm/` in the repo
# root. contains per-run meta.json / events.ndjson and the blackboard
# SQLite store. set this if you want runs persisted outside the repo
# (shared across checkouts, symlinked to an SSD, etc.).
OPENCODE_SWARM_ROOT=

# opencode's own log directory. only used by the Zen rate-limit probe
# (`lib/server/zen-rate-limit-probe.ts`) to distinguish a 429-throttled
# session from a truly frozen opencode process. on WSL, this is typically
# `/mnt/c/Users/<you>/.opencode-ui-separate/opencode/log`. if unset, the
# probe no-ops and every stall is attributed to "opencode-frozen".
OPENCODE_LOG_DIR=

# ── optional ollama pre-warm ────────────────────────────────────────────
# ollama daemon URL used by the run-creation pre-warm step (fires a
# tiny /api/generate per unique ollama model before the first /prompt
# dispatch, so cold-start latency doesn't hang opencode's prompt
# client). Default `http://localhost:11434` — correct when Next.js
# runs on the same host as ollama. WSL→Windows setups need
# `http://<windows-host-ip>:11434` because WSL's localhost != Windows's.
# Note: different from opencode.json's baseURL (that's from opencode's
# POV). See lib/server/blackboard/model-prewarm.ts.
OLLAMA_URL=

# ── optional opencode auto-restart ──────────────────────────────────────
# shell command to execute when the frozen watchdog stops a ticker with
# stopReason='opencode-frozen'. no-op when unset — zero-config behavior
# leaves the ticker stopped and relies on the user to manually restart
# opencode. on WSL pointing at a Windows-host opencode, this is typically
# a powershell one-liner like:
#   OPENCODE_RESTART_CMD='powershell.exe -Command "Start-Process opencode.exe"'
# debounced at 10 min so a restart into a still-broken opencode doesn't
# hammer. see `lib/server/opencode-restart.ts`.
OPENCODE_RESTART_CMD=

# ── optional retention ──────────────────────────────────────────────────
# enable auto-pruning of demo-log / events.ndjson files on dev startup.
# set to `1` to opt in. by default, only gzip compression runs — deletion
# of old runs is OFF unless this flag is set. see `lib/server/demo-log-
# retention.ts::pruneDemoLog()`.
DEMO_LOG_AUTO_DELETE=

# retention window in days when DEMO_LOG_AUTO_DELETE=1. runs older than
# this are deleted. defaults to 30.
DEMO_LOG_RETENTION_DAYS=

# ── optional dev server ─────────────────────────────────────────────────
# preferred port for `npm run dev`. `scripts/dev.mjs` rolls a sticky
# random port on first run and writes it to `.dev-port`; set DEV_PORT to
# override. ignored once `.dev-port` exists.
DEV_PORT=
